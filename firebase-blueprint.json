{
  "entities": {
    "DubbingRecord": {
      "title": "Dubbing Record",
      "description": "A record of a completed dubbing operation.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user ID of the owner." },
        "sourceText": { "type": "string" },
        "translatedText": { "type": "string" },
        "targetLang": { "type": "string" },
        "emotion": { "type": "string" },
        "vocalIdentity": { "type": "string" },
        "recommendedVoice": { "type": "string" },
        "confidence": { "type": "number" },
        "audioUrl": { "type": "string", "description": "URL to the dubbed audio (base64 or storage link)." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "sourceText", "translatedText", "targetLang", "createdAt"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Basic user information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "dubs": {
      "schema": "DubbingRecord",
      "description": "Collection of dubbing operations."
    },
    "users": {
      "schema": "UserProfile",
      "description": "Collection of user profiles."
    }
  }
}
